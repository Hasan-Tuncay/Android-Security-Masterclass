<?xml version="1.0" encoding="utf-8"?>
<!--
    app-attacker: Simulated Malicious Third-Party Application
    Package: com.hasantuncay.mobsec.attacker

    EDUCATIONAL PURPOSE:
    This application simulates a malicious app installed on the same device as the
    victim application (app-vulnerable). It demonstrates real-world IPC exploitation
    techniques used by adversaries to steal sensitive data from misconfigured apps.

    CURRENT EXPLOIT COVERAGE:
    - MASWE-0002 / Vector 4: FileProvider <root-path> exploitation via content:// URI

    FUTURE EXPLOIT COVERAGE (extensible architecture):
    - Exported ContentProvider exploitation (MASWE-0064)
    - Exported Activity data interception
    - Broadcast snooping
    - Intent sniffing

    NOTE: This app does NOT need any dangerous permissions. The FileProvider exploit
    works purely via FLAG_GRANT_READ_URI_PERMISSION — a standard Android permission
    grant mechanism that the victim app hands over voluntarily (unintentionally).
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.hasantuncay.mobsec.attacker"
    android:versionCode="1"
    android:versionName="1.0" >

    <uses-sdk
        android:minSdkVersion="26"
        android:targetSdkVersion="36" />

    <!--
      ⚠️ VULNERABLE SETUP (For educational demonstration only)
      The attacker app requests READ_LOGS to demonstrate MASWE-0001.
      On Android 4.1+ (API 16+), this permission is signature-level and will NOT
      be granted automatically. It must be granted via ADB:
      adb shell pm grant com.hasantuncay.mobsec.attacker android.permission.READ_LOGS
    -->
    <uses-permission android:name="android.permission.READ_LOGS" />

    <permission
        android:name="com.hasantuncay.mobsec.attacker.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"
        android:protectionLevel="signature" />

    <uses-permission android:name="com.hasantuncay.mobsec.attacker.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION" />

    <application
        android:allowBackup="true"
        android:appComponentFactory="androidx.core.app.CoreComponentFactory"
        android:debuggable="true"
        android:extractNativeLibs="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:testOnly="true"
        android:theme="@style/Theme.Attacker" >

        <!-- Main launcher activity — the attacker's control panel -->
        <activity
            android:name="com.hasantuncay.mobsec.attacker.AttackerMainActivity"
            android:exported="true"
            android:label="@string/app_name" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            EXPLOIT RECEIVER: FileProvider content:// URI handler
            MASWE-0002 / Vector 4

            This Activity is the entry point for the FileProvider exploit.
            When app-vulnerable triggers the FileProvider vector, it sends an
            explicit Intent to this activity with:
              - data = content:// URI pointing to victim's internal SharedPrefs file
              - FLAG_GRANT_READ_URI_PERMISSION

            This Activity then uses ContentResolver.openInputStream() to read
            the victim app's sensitive file — demonstrating the real exploit path.

            android:exported="true" is required for the victim app to start this
            activity via an explicit Intent from a different process.
        -->
        <activity
            android:name="androidx.compose.ui.tooling.PreviewActivity"
            android:exported="true" />

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="com.hasantuncay.mobsec.attacker.androidx-startup"
            android:exported="false" >
            <meta-data
                android:name="androidx.emoji2.text.EmojiCompatInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.lifecycle.ProcessLifecycleInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.profileinstaller.ProfileInstallerInitializer"
                android:value="androidx.startup" />
        </provider>

        <uses-library
            android:name="androidx.window.extensions"
            android:required="false" />
        <uses-library
            android:name="androidx.window.sidecar"
            android:required="false" />

        <activity
            android:name="androidx.activity.ComponentActivity"
            android:exported="true"
            android:theme="@android:style/Theme.Material.Light.NoActionBar" />

        <receiver
            android:name="androidx.profileinstaller.ProfileInstallReceiver"
            android:directBootAware="false"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.DUMP" >
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.INSTALL_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SKIP_FILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SAVE_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.BENCHMARK_OPERATION" />
            </intent-filter>
        </receiver>
    </application>

</manifest>